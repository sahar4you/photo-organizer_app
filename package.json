{
  "name": "photo-organizer",
  "version": "1.2.0",
  "description": "Google Photos-style offline photo organizer with face detection",
  "main": "main.js",
  "scripts": {
    "postinstall": "python python/setup_env.py || python3 python/setup_env.py || echo [WARN] Python dependency setup skipped - Python not found",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build-portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.indiatech247.photo-organizer",
    "productName": "PhotoOrganizer",
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!python_scanner",
      "!python_bin"
    ],
    "extraResources": [
      {
        "from": "python_bin",
        "to": "python_bin"
      },
      {
        "from": "python_scanner/models",
        "to": "models"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    },
    "portable": {
      "artifactName": "PhotoOrganizer-Portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
